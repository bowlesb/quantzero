# Copy to .env and fill in. .env is gitignored.
# Alpaca market data + trading credentials.
ALPACA_KEY_ID=your_key_id
ALPACA_SECRET_KEY=your_secret_key
# Data feed: "sip" (paid, full consolidated tape) or "iex" (free, partial).
ALPACA_DATA_FEED=sip
# REST data endpoint (default is fine).
ALPACA_DATA_URL=https://data.alpaca.markets

# Where computed feature vectors are written (parquet feature store root).
QZ_STORE_ROOT=./store

# Prometheus metrics HTTP port for the live runner (0 = disabled).
QZ_METRICS_PORT=9300
